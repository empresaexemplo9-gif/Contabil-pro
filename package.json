{
  "name": "contabilpro",
  "version": "0.1.0",
  "private": true,
  "description": "ContabilPro — Plataforma de gestão contábil digital multi-tenant",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=20.10.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "test:e2e": "turbo run test:e2e",
    "type-check": "turbo run type-check",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "db:gerar": "pnpm --filter @contabilpro/database run db:gerar",
    "db:migrar": "pnpm --filter @contabilpro/database run db:migrar",
    "db:semear": "pnpm --filter @contabilpro/database run db:semear",
    "db:estudio": "pnpm --filter @contabilpro/database exec prisma studio",
    "db:rls": "pnpm --filter @contabilpro/database run db:rls",
    "infra:subir": "docker compose -f infra/compose/docker-compose.yml up -d",
    "infra:descer": "docker compose -f infra/compose/docker-compose.yml down",
    "infra:logs": "docker compose -f infra/compose/docker-compose.yml logs -f",
    "preparar": "husky"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "husky": "^9.1.6",
    "lint-staged": "^15.2.10",
    "prettier": "^3.3.3",
    "tsx": "^4.19.1",
    "turbo": "^2.1.3",
    "typescript": "^5.6.3"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": ["prettier --write"],
    "*.{json,md,yml,yaml}": ["prettier --write"]
  }
}
