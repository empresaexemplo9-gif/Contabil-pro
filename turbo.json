{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": ["**/.env.*local", "**/.env"],
  "globalEnv": ["NODE_ENV"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"],
      "env": [
        "DATABASE_URL",
        "DIRECT_URL",
        "JWT_PRIVATE_KEY",
        "JWT_PUBLIC_KEY",
        "QSTASH_TOKEN",
        "QSTASH_CURRENT_SIGNING_KEY",
        "QSTASH_NEXT_SIGNING_KEY",
        "CRON_SECRET",
        "BLOB_READ_WRITE_TOKEN",
        "BLOB_PUBLIC_URL",
        "RESEND_API_KEY",
        "WHATSAPP_*",
        "SENTRY_DSN",
        "NEXT_PUBLIC_*"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "outputs": []
    },
    "test": {
      "outputs": ["coverage/**"]
    },
    "test:e2e": {
      "cache": false,
      "outputs": ["playwright-report/**"]
    },
    "type-check": {
      "outputs": []
    },
    "db:gerar": {
      "cache": false
    }
  }
}
