# ============================================================================
# ContabilPro — variáveis de ambiente (exemplo)
# Copie para .env e preencha com valores reais. NUNCA comite .env.
# ============================================================================

# --- Ambiente ---
NODE_ENV=development
TZ=America/Sao_Paulo

# --- API ---
API_PORT=3333
API_URL=http://localhost:3333
WEB_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000

# --- Banco de dados (PostgreSQL) ---
DATABASE_URL=postgresql://contabilpro:contabilpro@localhost:5432/contabilpro?schema=public

# --- Redis (cache e filas) ---
REDIS_URL=redis://localhost:6379

# --- JWT (RS256) — gerar com `openssl genrsa` ---
# Em produção, manter em gerenciador de segredos (Doppler/SOPS/Secrets Manager).
JWT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# --- Storage (S3-compatível: AWS S3, Cloudflare R2, MinIO local) ---
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=contabilpro
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_FORCE_PATH_STYLE=true

# --- E-mail (Resend) ---
RESEND_API_KEY=
EMAIL_REMETENTE_PADRAO=no-reply@contabilpro.com.br

# --- WhatsApp Cloud API (Meta) ---
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=

# --- Assinatura eletrônica (escolher provedor) ---
ASSINATURA_PROVEDOR=zapsign
ZAPSIGN_API_TOKEN=

# --- Login com Google (OAuth 2.0) ---
# Crie credenciais em https://console.cloud.google.com/apis/credentials
# Tipo: "Web application"
# Origens autorizadas: WEB_URL (ex.: http://localhost:3000)
# URI de redirecionamento: API_URL/api/v1/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3333/api/v1/auth/google/callback

# --- Observabilidade ---
SENTRY_DSN=
LOG_LEVEL=info

# --- Frontend (Next.js) ---
NEXT_PUBLIC_API_URL=http://localhost:3333
NEXT_PUBLIC_AMBIENTE=development
