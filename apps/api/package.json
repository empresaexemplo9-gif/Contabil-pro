{
  "name": "@contabilpro/api",
  "version": "0.1.0",
  "private": true,
  "description": "API REST do ContabilPro (NestJS)",
  "main": "dist/main.js",
  "scripts": {
    "build": "nest build",
    "dev": "nest start --watch",
    "start": "node dist/main.js",
    "lint": "eslint \"src/**/*.ts\"",
    "type-check": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "vitest run --config vitest.e2e.config.ts"
  },
  "dependencies": {
    "@contabilpro/auth-core": "workspace:*",
    "@contabilpro/contracts": "workspace:*",
    "@contabilpro/database": "workspace:*",
    "@contabilpro/integracoes": "workspace:*",
    "@contabilpro/logger": "workspace:*",
    "@contabilpro/utils": "workspace:*",
    "@nestjs/bullmq": "^10.2.1",
    "@nestjs/common": "^10.4.6",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.6",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.4.6",
    "@nestjs/swagger": "^8.0.1",
    "@nestjs/throttler": "^6.2.1",
    "@nestjs/websockets": "^10.4.6",
    "@nestjs/platform-socket.io": "^10.4.6",
    "socket.io": "^4.8.0",
    "@aws-sdk/client-s3": "^3.677.0",
    "@aws-sdk/s3-request-presigner": "^3.677.0",
    "bullmq": "^5.21.2",
    "helmet": "^8.0.0",
    "ioredis": "^5.4.1",
    "nestjs-pino": "^4.1.0",
    "nestjs-zod": "^4.3.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@contabilpro/config-eslint": "workspace:*",
    "@contabilpro/config-typescript": "workspace:*",
    "@nestjs/cli": "^10.4.7",
    "@nestjs/schematics": "^10.2.3",
    "@nestjs/testing": "^10.4.6",
    "@types/express": "^5.0.0",
    "@types/node": "^20.14.10",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^6.0.2",
    "supertest": "^7.0.0",
