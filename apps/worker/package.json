{
  "name": "@contabilpro/worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/main.ts",
    "start": "node dist/main.js",
    "lint": "eslint \"src/**/*.ts\"",
    "type-check": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.677.0",
    "@aws-sdk/s3-request-presigner": "^3.677.0",
    "@contabilpro/contracts": "workspace:*",
    "@contabilpro/database": "workspace:*",
    "@contabilpro/logger": "workspace:*",
    "@contabilpro/utils": "workspace:*",
    "bullmq": "^5.21.2",
    "ioredis": "^5.4.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@contabilpro/config-eslint": "workspace:*",
    "@contabilpro/config-typescript": "workspace:*",
    "@types/node": "^20.14.10",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3",
    "vitest": "^2.1.3"
  }
}
